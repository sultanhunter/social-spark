# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=

# Google Gemini
GOOGLE_GEMINI_API_KEY=

# Decodo ISP Proxy (optional, recommended for social scraping)
DECODO_PROXY_HOST=isp.decodo.com
DECODO_PROXY_PORT=
DECODO_PROXY_USERNAME=
DECODO_PROXY_PASSWORD=
DECODO_PROXY_USE_SESSION=true

# Optional remote extractor service (recommended for Vercel production)
SOCIAL_EXTRACTOR_API_URL=
SOCIAL_EXTRACTOR_API_TOKEN=

# Optional Instagram publishing (Graph API)
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_GRAPH_USER_ID=
INSTAGRAM_GRAPH_API_VERSION=v22.0

# AI Agent Bot Token
AGENT_BOT_TOKEN=

# Muslimah Pro Blog API (AI blog agent)
MUSLIMAH_BLOG_API_BASE_URL=https://muslimahpro.com
MUSLIMAH_BLOG_API_KEY=

# Remote worker server for long blog generation
BLOG_AGENT_WORKER_URL=https://your-worker-domain.com/api/blog-agent/generate
BLOG_AGENT_WORKER_TOKEN=
